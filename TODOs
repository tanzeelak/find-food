      Goal: user B can request access to user A's profile; user A approves/denies in settings panel.

    --- STEP 1: Supabase schema (run in SQL Editor) ---
    [ ] Create profile_access_requests table:
          create table public.profile_access_requests (
            id uuid primary key default gen_random_uuid(),
            owner_id uuid references auth.users(id) on delete cascade,
            requester_id uuid references auth.users(id) on delete cascade,
            created_at timestamptz default now(),
            unique (owner_id, requester_id)
          );
          -- RLS: owner/requester can SELECT; only requester can INSERT; both can DELETE
          alter table public.profile_access_requests enable row level security;
          create policy "requests_select" on public.profile_access_requests
            for select using (auth.uid() = owner_id or auth.uid() = requester_id);
          create policy "requests_insert" on public.profile_access_requests
            for insert with check (auth.uid() = requester_id);
          create policy "requests_delete" on public.profile_access_requests
            for delete using (auth.uid() = owner_id or auth.uid() = requester_id);

